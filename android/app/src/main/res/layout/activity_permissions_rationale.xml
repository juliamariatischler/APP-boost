<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="28dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚡"
            android:textSize="48sp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="BoostSchule"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#15803D"
            android:gravity="center"
            android:layout_marginTop="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Zugriff auf Gesundheitsdaten"
            android:textSize="17sp"
            android:textColor="#374151"
            android:gravity="center"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="28dp" />

        <!-- Card: what data -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="18dp"
            android:layout_marginBottom="14dp"
            android:elevation="2dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Welche Daten werden gelesen?"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#111827"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="👟  Schrittzahl (über Health Connect by Android)"
                android:textSize="14sp"
                android:textColor="#374151"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nur Lesezugriff – die App schreibt keine Daten zurück."
                android:textSize="13sp"
                android:textColor="#6B7280"
                android:layout_marginTop="6dp" />
        </LinearLayout>

        <!-- Card: why -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="18dp"
            android:layout_marginBottom="14dp"
            android:elevation="2dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Warum braucht BoostSchule diese Daten?"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#111827"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• Deinen täglichen Bewegungsfortschritt anzeigen\n• Klassen-Fitness-Challenges ermöglichen\n• Dein Aktivitätsziel in der App verfolgen"
                android:textSize="14sp"
                android:textColor="#374151"
                android:lineSpacingMultiplier="1.4" />
        </LinearLayout>

        <!-- Card: data protection -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="18dp"
            android:layout_marginBottom="28dp"
            android:elevation="2dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Datenschutz"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#111827"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• Deine Schritt-Daten werden nicht an Dritte weitergegeben\n• Daten werden nicht auf Servern gespeichert\n• Du kannst den Zugriff jederzeit in Health Connect widerrufen"
                android:textSize="14sp"
                android:textColor="#374151"
                android:lineSpacingMultiplier="1.4"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/link_privacy_policy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Datenschutzerklärung lesen →"
                android:textSize="14sp"
                android:textColor="#16A34A"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- Button -->
        <Button
            android:id="@+id/btn_understood"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Verstanden"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#16A34A"
            android:layout_marginBottom="16dp" />

    </LinearLayout>
</ScrollView>
